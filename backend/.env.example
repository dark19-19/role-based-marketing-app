# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/veronicaDB
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/Seeder-test
# Auth
JWT_SECRET=xxxxxxxxxxxx

# Encryption (AES-256-GCM key; base64/hex/utf8). Keep secret!
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxx

# Jobs - Notifications cleanup (daily)
# Hour of day (local server time) to run cleanup: 0-23
NOTIFICATIONS_CLEANUP_HOUR=3
# Keep only the most recent N notifications (soft delete the older ones)
NOTIFICATIONS_MAX_COUNT=1000
NOTIFICATIONS_HARD_DELETE_AFTER_DAYS=7
PRODUCTS_LIST_CACHE_TTL_SECONDS=600
# Admin accounts
ADMIN_1_PHONE=0912345678
ADMIN_1_PASSWORD=12345678
ADMIN_2_PHONE=0932068925
ADMIN_2_PASSWORD=admin@admin.admin
ADMIN_3_PHONE=
ADMIN_3_PASSWORD=
ADMIN_4_PHONE=
ADMIN_4_PASSWORD=
ADMIN_5_PHONE=
ADMIN_5_PASSWORD=

#server  connection setup
SERVER_MAX_CONCURRENT_CONNECTIONS_PER_IP=40
SERVER_CONNECTION_WINDOW_MS=3000
SERVER_MAX_CONNECTIONS_PER_IP_WINDOW=40
SERVER_HEADERS_TIMEOUT_MS=6000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_SOCKET_IDLE_TIMEOUT_MS=6000
SERVER_SLOW_MIN_BYTES=350
SERVER_SLOW_PARTIAL_IDLE_MS=3000
SERVER_SLOW_NO_DATA_IDLE_MS=4000

#unit test timeout
JEST_TEST_TIMEOUT_MS=30000
